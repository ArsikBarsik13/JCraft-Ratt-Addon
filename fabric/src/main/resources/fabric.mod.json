{
  "schemaVersion": 1,
  "id": "ratt",
  "version": "${version}",
  "name": "JCraft Ratt Addon",
  "description": "This addon adds the Ratt stand from JoJo's Bizzare Adventure Part 4 Diamond Is Unbreakable to JCraft: Eyes Of Ender!",
  "authors": [
    "Arsik"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "MIT",
  "icon": "assets/ratt/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.arsik.ratt.fabric.RattFabric"
    ],
    "client": [
      "net.arsik.ratt.fabric.client.RattFabricClient"
    ],
    "fabric-datagen": [
      "net.arsik.ratt.fabric.datagen.RattDataGen"
    ]
  },
  "mixins": [
    "ratt.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.14",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "architectury": ">=9.2.14",
    "jcraft": ">=0.18.0"
  }
}
